us_economy_pulse:
  target: dev
  outputs:
    dev:
      type: postgres
      host: "{{ env_var('SUPABASE_HOST') }}"
      port: "{{ env_var('SUPABASE_PORT', 5432) | int }}"
      user: "{{ env_var('SUPABASE_USER') }}"
      password: "{{ env_var('SUPABASE_PASSWORD') }}"
      dbname: "{{ env_var('SUPABASE_DBNAME') }}"
      schema: public
      threads: 4
      keepalives_idle: 0
      application_name: dbt_us_economy_pulse
      sslmode: require

# To use this file:
# 1. Copy this file to ~/.dbt/profiles.yml
# 2. Set environment variables:
#    export SUPABASE_HOST=your-project.supabase.co
#    export SUPABASE_PORT=5432  # or 6543 for connection pooler
#    export SUPABASE_USER=postgres
#    export SUPABASE_PASSWORD=your_password
#    export SUPABASE_DBNAME=postgres
# 3. Run dbt commands: dbt run, dbt test, etc.
