# ──────────────────────────────────────────────────────────────────────────────
# US Economy Pulse — Streamlit Secrets
#
# HOW TO USE:
#
# LOCAL DEV:
#   Copy this file to:  dashboard/.streamlit/secrets.toml
#   Fill in your real Supabase values, then run:  streamlit run dashboard/app.py
#   (secrets.toml is in .gitignore — never commit it)
#
# STREAMLIT CLOUD:
#   Go to your app → ⋮ menu → Settings → Secrets
#   Paste the [supabase] block below with your real values
# ──────────────────────────────────────────────────────────────────────────────

[supabase]
# Transaction pooler connection (same as what dbt uses)
# Get these from: Supabase → Settings → Database → Connection string → Transaction pooler

host     = "aws-1-us-east-1.pooler.supabase.com"   # your actual pooler host
port     = 6543
dbname   = "postgres"
user     = "postgres.YOUR_PROJECT_REF"              # e.g. postgres.rdixumqbodyyxpswvjow
password = "YOUR_DATABASE_PASSWORD"
